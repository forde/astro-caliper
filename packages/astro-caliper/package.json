{
  "name": "astro-caliper",
  "version": "1.1.0",
  "description": "Astro toolbar app designed to assist developers in converting designs to code. It provides visual aids and inspection tools directly within the browser.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && cp -r src/assets dist/",
    "dev": "nodemon --watch src --ext ts,svg --exec \"pnpm build\"",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "astro": "^5.15.9",
    "nodemon": "^3.1.14",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "dev-toolbar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/forde/astro-caliper",
    "directory": "packages/astro-caliper"
  },
  "author": "Konrad Węgrzyniak <konrad@forde.pl>",
  "license": "MIT",
  "homepage": "https://github.com/forde/astro-caliper#readme",
  "bugs": {
    "url": "https://github.com/forde/astro-caliper/issues"
  }
}